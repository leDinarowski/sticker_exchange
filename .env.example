# ─────────────────────────────────────────────────────────────────────────────
# sticker_exchange — environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Evolution API ─────────────────────────────────────────────────────────────
# Base URL of your self-hosted Evolution API instance on Railway
EVOLUTION_API_URL=https://your-evolution-api.up.railway.app
# API key set during Evolution API setup
EVOLUTION_API_KEY=your_evolution_api_key
# The name of the WhatsApp instance configured in Evolution API
EVOLUTION_INSTANCE_NAME=sticker_exchange

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service role key — has full DB access, never expose to clients
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Anon key — used for client-side queries (if ever needed)
SUPABASE_ANON_KEY=your_anon_key

# ── Webhook Security ──────────────────────────────────────────────────────────
# A random secret to validate that webhook calls come from Evolution API
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret

# ── App Config ────────────────────────────────────────────────────────────────
# Environment: development | production
NODE_ENV=development
# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
